"<h1 id="xss-torture-post">XSS torture post</h1>
<p>&lt;script&gt;alert('xss-1')&lt;/script&gt;</p>
<p>&lt;img src=x onerror=&quot;alert('xss-2')&quot;&gt;</p>
<p>[click me](javascript:alert('xss-3'))</p>
<p>&lt;a href=&quot;javascript:alert('xss-4')&quot;&gt;anchor&lt;/a&gt;</p>
<p>&lt;iframe src=&quot;<a href="https://evil.example.com" rel="nofollow noopener">https://evil.example.com</a>&quot;&gt;&lt;/iframe&gt;</p>
<p>&lt;svg onload=&quot;alert('xss-5')&quot;&gt;&lt;/svg&gt;</p>
<p>&lt;style&gt;body { background: url('<a href="https://evil.example.com/steal" rel="nofollow noopener">https://evil.example.com/steal</a>') }&lt;/style&gt;</p>
<p>&lt;/style&gt;&lt;script&gt;alert('xss-6')&lt;/script&gt;</p>
<p>&lt;div onclick=&quot;alert('xss-7')&quot;&gt;div handler&lt;/div&gt;</p>
<p></p>
<p>&lt;a href=&quot;data:text/html,&lt;script&gt;alert('xss-9')&lt;/script&gt;&quot;&gt;data url&lt;/a&gt;</p>
<pre><code class="hljs language-html"><span class="hljs-tag">&lt;<span class="hljs-name">script</span>&gt;</span><span class="language-javascript"><span class="hljs-title function_">alert</span>(<span class="hljs-string">&#x27;inside-code-block-should-render-as-text&#x27;</span>)</span><span class="hljs-tag">&lt;/<span class="hljs-name">script</span>&gt;</span>
</code></pre>
"
`;

