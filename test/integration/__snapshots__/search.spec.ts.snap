exports[`search (P6) > search page > renders results with links to the posts' blog URLs 1`] = `"<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Search — nbread.lol</title><link rel="icon" type="image/svg+xml" href="/favicon.svg"/><link rel="stylesheet" href="/css/style.css"/></head><body class="apex"><header class="site-header"><a class="site-brand" href="/"><img src="/logo.svg" width="28" height="28" alt=""/> nbread.lol</a><nav class="site-nav-links"><a href="/discover">Discover</a><a href="/search" aria-current="page">Search</a><a href="/docs">Docs</a><a href="/login">Log in</a></nav></header><main class="search"><h1>Search</h1><form method="get" action="/search" class="search-form" role="search"><input type="search" name="q" value="hello" maxlength="256" placeholder="Search posts" aria-label="Search posts"/> <button type="submit">Search</button></form><p class="search-count">1 result for “hello”</p><ul class="post-list feed-list"><li class="post-item"><a class="post-link" href="https://alice.nbread.lol/hello-world">Hello world</a> <span class="post-author">by <a href="https://alice.nbread.lol/">@alice</a></span> <time class="post-date" datetime="2023-11-14">2023-11-14</time><p class="post-summary">Alice&#39;s first nbread.lol test post</p></li></ul></main><footer class="site-footer"><p><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> · <a href="/docs">Docs</a> · <a href="https://github.com/sovITxyz/nbread" rel="noopener">Source (AGPL)</a></p><p>Created by <a href="https://sovit.xyz" rel="noopener">sovit.xyz</a> — inspired by <a href="https://herman.bearblog.dev" rel="noopener">Herman</a>&#39;s <a href="https://bearblog.dev" rel="noopener">Bear Blog</a>.</p></footer></body></html>"`;

